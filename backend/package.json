{
  "name": "zealthy-emr-backend",
  "private": true,
  "scripts": {
    "dev": "node scripts/run-with-env.mjs node scripts/dev.mjs",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "start": "node scripts/run-with-env.mjs node dist/main.js",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "db:generate": "node scripts/run-with-env.mjs prisma generate",
    "db:migrate": "node scripts/run-with-env.mjs prisma migrate dev",
    "db:deploy": "node scripts/run-with-env.mjs prisma migrate deploy",
    "db:seed": "node scripts/run-with-env.mjs tsx prisma/seed.ts",
    "db:studio": "node scripts/run-with-env.mjs prisma studio"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "@prisma/client": "^6.1.0",
    "bcryptjs": "^3.0.3",
    "chokidar": "^4.0.3",
    "cookie-parser": "^1.4.7",
    "date-fns": "^4.1.0",
    "jose": "^6.2.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.3.0",
    "@nestjs/testing": "^11.1.19",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.33",
    "@types/cookie-parser": "^1.4.9",
    "@types/express": "^5.0.3",
    "@types/node": "^22.10.2",
    "@types/supertest": "^6.0.3",
    "prisma": "^6.1.0",
    "supertest": "^7.2.2",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^5.4.19",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=20"
  }
}
